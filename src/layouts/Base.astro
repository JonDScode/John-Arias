---
interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = "John Arias — fotografía y video en Vic, Barcelona. Bodas, quinceañeras, retratos, producto y eventos.",
} = Astro.props;

const base = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />
    <!-- En revisión: no indexar. Quitar al lanzar con dominio propio. -->
    <meta name="robots" content="noindex, nofollow" />
    <meta name="theme-color" content="#0c0c0c" />
    <script is:inline>document.documentElement.classList.add("js");</script>
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300..500;1,9..144,300..500&family=Inter:wght@400;500&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <header class="site-header">
      <div class="wrap">
        <a href={`${base}/`} class="wordmark">John Arias <span>— Fotografía</span></a>
        <nav class="site-nav">
          <a href="#video">Video</a>
          <a href="#trabajo">Trabajo</a>
          <a href="#sobre-mi">Sobre mí</a>
          <a href="#contacto">Contacto</a>
        </nav>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <div class="wrap">
        <span>© {new Date().getFullYear()} John Arias</span>
        <span>Todas las imágenes son propiedad del autor</span>
      </div>
    </footer>

    <script>
      if (!window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
        const io = new IntersectionObserver(
          (entries) => {
            for (const e of entries) {
              if (e.isIntersecting) {
                e.target.classList.add("visible");
                io.unobserve(e.target);
              }
            }
          },
          { threshold: 0.15, rootMargin: "0px 0px -40px 0px" },
        );
        document.querySelectorAll(".reveal").forEach((el) => io.observe(el));

        // Escalonado dentro de la retícula: cada columna entra con un pequeño retraso
        document.querySelectorAll(".work-grid").forEach((grid) => {
          [...grid.children].forEach((el, i) => {
            el.style.setProperty("--reveal-delay", `${(i % 3) * 100}ms`);
          });
        });

        // Video que se reproduce solo al entrar en pantalla (y se pausa al salir)
        const scrollVideos = document.querySelectorAll("video[data-scroll-play]");
        if (scrollVideos.length) {
          const vio = new IntersectionObserver(
            (entries) => {
              for (const e of entries) {
                const v = e.target;
                if (e.isIntersecting) {
                  v.muted = true;
                  v.play().catch(() => {});
                } else {
                  v.pause();
                }
              }
            },
            { threshold: 0.4 },
          );
          scrollVideos.forEach((v) => vio.observe(v));
        }

        // Parallax sutil del hero: se desplaza y desvanece al hacer scroll
        const hero = document.querySelector(".hero-inner");
        if (hero) {
          let ticking = false;
          window.addEventListener(
            "scroll",
            () => {
              if (ticking) return;
              ticking = true;
              requestAnimationFrame(() => {
                const p = Math.min(window.scrollY / window.innerHeight, 1);
                hero.style.transform = `translateY(${window.scrollY * 0.25}px)`;
                hero.style.opacity = String(1 - p * 0.9);
                ticking = false;
              });
            },
            { passive: true },
          );
        }
      }

      // Obturador: clic en una foto = tomar una foto (animación + sonido)
      let actx;
      function shutterSound() {
        try {
          actx = actx || new (window.AudioContext || window.webkitAudioContext)();
          const click = (t, dur, freq, vol) => {
            const buf = actx.createBuffer(1, Math.floor(actx.sampleRate * dur), actx.sampleRate);
            const d = buf.getChannelData(0);
            for (let i = 0; i < d.length; i++) {
              d[i] = (Math.random() * 2 - 1) * Math.pow(1 - i / d.length, 2);
            }
            const src = actx.createBufferSource();
            src.buffer = buf;
            const f = actx.createBiquadFilter();
            f.type = "bandpass";
            f.frequency.value = freq;
            f.Q.value = 1.1;
            const g = actx.createGain();
            g.gain.value = vol;
            src.connect(f);
            f.connect(g);
            g.connect(actx.destination);
            src.start(t);
          };
          const t0 = actx.currentTime;
          click(t0, 0.03, 2600, 0.5); // espejo sube
          click(t0 + 0.1, 0.06, 1300, 0.8); // obturador
        } catch (e) {
          /* sin audio, la animación sigue */
        }
      }

      document.querySelectorAll(".work-item").forEach((item) => {
        item.addEventListener("click", (ev) => {
          ev.preventDefault();
          const fig = item.querySelector("figure");
          let sh = fig.querySelector(".shutter");
          if (!sh) {
            sh = document.createElement("div");
            sh.className = "shutter";
            sh.innerHTML =
              '<div class="blade top"></div><div class="blade bottom"></div><div class="flash"></div>';
            fig.appendChild(sh);
          }
          sh.classList.remove("firing");
          void sh.offsetWidth; // reinicia la animación
          sh.classList.add("firing");
          shutterSound();
          setTimeout(() => sh.classList.remove("firing"), 650);
        });
      });
    </script>
  </body>
</html>

<style is:global>
  @import "../styles/global.css";
</style>
