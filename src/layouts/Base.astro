---
interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = "John Arias — fotografía y video en Vic, Barcelona. Bodas, quinceañeras, retratos, producto y eventos.",
} = Astro.props;

const base = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />
    <!-- En revisión: no indexar. Quitar al lanzar con dominio propio. -->
    <meta name="robots" content="noindex, nofollow" />
    <meta name="theme-color" content="#0c0c0c" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300..500;1,9..144,300..500&family=Inter:wght@400;500&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <header class="site-header">
      <div class="wrap">
        <a href={`${base}/`} class="wordmark">John Arias <span>— Fotografía</span></a>
        <nav class="site-nav">
          <a href="#trabajo">Trabajo</a>
          <a href="#video">Video</a>
          <a href="#sobre-mi">Sobre mí</a>
          <a href="#contacto">Contacto</a>
        </nav>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <div class="wrap">
        <span>© {new Date().getFullYear()} John Arias</span>
        <span>Todas las imágenes son propiedad del autor</span>
      </div>
    </footer>
  </body>
</html>

<style is:global>
  @import "../styles/global.css";
</style>
