---
import Base from "../layouts/Base.astro";

const base = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<Base title="Página no encontrada — John Arias">
  <section class="hero wrap">
    <p class="eyebrow">Error 404</p>
    <h1>Esta página <em>no existe</em></h1>
    <p class="lede">
      El enlace que seguiste no lleva a ninguna parte.
      <a href={`${base}/`} style="color: var(--accent); text-decoration: underline;">Volver al inicio</a>
    </p>
  </section>
</Base>
