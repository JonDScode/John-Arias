---
import Base from "../layouts/Base.astro";

const base = import.meta.env.BASE_URL.replace(/\/$/, "");

const works = [
  { src: `${base}/photos/ig-01.jpg`, title: "Bodas — Ceremonia", year: "2026", ratio: "4 / 5", size: "" },
  { src: `${base}/photos/ig-09.jpg`, title: "Retratos — Sesión exterior", year: "2025", ratio: "2 / 3", size: "" },
  { src: `${base}/photos/ig-04.jpg`, title: "Quinceañeras — Jessy", year: "2026", ratio: "3 / 4", size: "narrow" },
  { src: `${base}/photos/ig-12.jpg`, title: "Eventos — Fiesta de XV", year: "2025", ratio: "3 / 4", size: "narrow" },
  { src: `${base}/photos/ig-06.jpg`, title: "Quinceañeras — Isabel Sofía", year: "2025", ratio: "3 / 4", size: "narrow" },
  { src: `${base}/photos/food-burger.jpg`, title: "Gastronomía — Carta de restaurante", year: "2026", ratio: "4 / 5", size: "" },
  { src: `${base}/photos/chef-plato.jpg`, title: "Gastronomía — El chef y su plato", year: "2026", ratio: "4 / 5", size: "" },
  { src: `${base}/photos/food-helado.jpg`, title: "Gastronomía — Postres", year: "2026", ratio: "3 / 4", size: "narrow" },
  { src: `${base}/photos/producto-set.jpg`, title: "Producto — Detrás de cámara", year: "2026", ratio: "3 / 4", size: "narrow" },
  { src: `${base}/photos/food-pollo.jpg`, title: "Gastronomía — Detalle de carta", year: "2026", ratio: "3 / 4", size: "narrow" },
  { src: `${base}/photos/xv-azul.jpg`, title: "Quinceañeras — Sesión en jardín", year: "2026", ratio: "4 / 5", size: "" },
  { src: `${base}/photos/ig-11.jpg`, title: "Retrato urbano — 18 años", year: "2025", ratio: "4 / 5", size: "" },
];
---

<Base title="John Arias — Fotografía y Video">
  <section class="hero wrap">
    <div class="hero-inner">
      <p class="eyebrow">Fotografía y video — Vic, Barcelona</p>
      <h1>Recuerdos que duran <em>para siempre</em></h1>
      <p class="lede">
        Bodas, quinceañeras, retratos, producto y eventos. Fotografía y video
        para congelar los momentos que se viven una sola vez.
      </p>
      <p class="scroll-hint">Desliza para ver el trabajo ↓</p>
    </div>
  </section>

  <div class="filmstrip" aria-hidden="true">
    <div class="filmstrip-track">
      {
        [...works, ...works].map((w) => (
          <img src={w.src} alt="" loading="lazy" />
        ))
      }
    </div>
  </div>

  <section class="section" id="video">
    <div class="wrap">
      <div class="section-head reveal">
        <h2>Video</h2>
        <p class="eyebrow">Contenido audiovisual</p>
      </div>
      <div class="video-grid">
        <figure class="reveal">
          <video src={`${base}/videos/reel-01.mp4`} controls preload="metadata" playsinline></video>
          <figcaption>Comunión — Vic</figcaption>
        </figure>
        <figure class="reveal" style="--reveal-delay: 120ms">
          <video
            src={`${base}/videos/reel-02.mp4`}
            data-scroll-play
            muted
            loop
            controls
            preload="metadata"
            playsinline
          ></video>
          <figcaption>Fiesta de XV — se reproduce al llegar aquí</figcaption>
        </figure>
      </div>
    </div>
  </section>

  <section class="section" id="trabajo">
    <div class="wrap">
      <div class="section-head reveal">
        <h2>Trabajo seleccionado</h2>
        <p class="eyebrow">2024 — 2026 · Haz clic en una foto 📸</p>
      </div>
      <div class="work-grid">
        {
          works.map((w) => (
            <a class={`work-item reveal ${w.size}`} href="#trabajo">
              <figure>
                <img
                  src={w.src}
                  alt={w.title}
                  loading="lazy"
                  style={`--ratio: ${w.ratio}`}
                />
                <figcaption>
                  <span>{w.title}</span>
                  <span>{w.year}</span>
                </figcaption>
              </figure>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section" id="sobre-mi">
    <div class="wrap about reveal">
      <p class="eyebrow">Sobre mí</p>
      <div>
        <p class="bio">
          Soy John Arias, fotógrafo y creador de contenido audiovisual. Acompaño bodas, quinces y celebraciones <em>creando recuerdos</em> que duran para siempre.
        </p>
        <div class="meta">
          <span>Producto · Retratos · Bodas · Eventos</span>
          <span>Vic, Barcelona — disponible para desplazarse</span>
        </div>
      </div>
    </div>
  </section>

  <section class="section contact" id="contacto">
    <div class="wrap reveal">
      <p class="eyebrow">Contacto</p>
      <h2>Hablemos de tu próxima celebración</h2>

      <form
        class="lead-form"
        action="https://formsubmit.co/jonnathanospinam@gmail.com"
        method="POST"
      >
        <input type="hidden" name="_subject" value="Nueva solicitud desde el portafolio" />
        <input type="hidden" name="_captcha" value="false" />
        <input type="hidden" name="_next" value="https://jondscode.github.io/John-Arias/gracias/" />
        <input type="text" name="_honey" style="display:none" tabindex="-1" autocomplete="off" />

        <div class="form-row">
          <label>
            Nombre
            <input required type="text" name="nombre" placeholder="Tu nombre" />
          </label>
          <label>
            Email
            <input required type="email" name="email" placeholder="tu@correo.com" />
          </label>
        </div>
        <div class="form-row">
          <label>
            Servicio
            <select name="servicio">
              <option>Bodas</option>
              <option>Quinceañeras</option>
              <option>Retratos</option>
              <option>Producto / Gastronomía</option>
              <option>Eventos</option>
              <option>Otro</option>
            </select>
          </label>
          <label>
            Fecha del evento (opcional)
            <input type="date" name="fecha" />
          </label>
        </div>
        <label>
          Cuéntame tu idea
          <textarea name="mensaje" rows="4" placeholder="Qué celebras, dónde, qué tienes en mente..."></textarea>
        </label>
        <button type="submit">Enviar solicitud</button>
        <p class="form-note">
          También puedes escribir directo por Instagram:
          <a href="https://www.instagram.com/johnarias80/" target="_blank" rel="noopener" style="color: var(--accent);">@johnarias80</a>
        </p>
      </form>
    </div>
  </section>
</Base>
