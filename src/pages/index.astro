---
import Base from "../layouts/Base.astro";

const works = [
  { src: "/photos/ig-01.jpg", title: "Bodas — Ceremonia", year: "2026", ratio: "4 / 5", size: "" },
  { src: "/photos/ig-09.jpg", title: "Retratos — Sesión exterior", year: "2025", ratio: "2 / 3", size: "" },
  { src: "/photos/ig-04.jpg", title: "Quinceañeras — Jessy", year: "2026", ratio: "3 / 4", size: "narrow" },
  { src: "/photos/ig-12.jpg", title: "Eventos — Fiesta de XV", year: "2025", ratio: "3 / 4", size: "narrow" },
  { src: "/photos/ig-06.jpg", title: "Quinceañeras — Isabel Sofía", year: "2025", ratio: "3 / 4", size: "narrow" },
  { src: "/photos/ig-05.jpg", title: "Sesión pre-quince — Sofía", year: "2026", ratio: "4 / 5", size: "narrow" },
  { src: "/photos/ig-07.jpg", title: "Detrás de cámara — Comunión", year: "2026", ratio: "3 / 4", size: "narrow" },
  { src: "/photos/ig-11.jpg", title: "Retrato urbano — 18 años", year: "2025", ratio: "3 / 4", size: "narrow" },
];
---

<Base title="John Arias — Fotografía y Video">
  <section class="hero wrap">
    <p class="eyebrow">Fotografía y video — Colombia</p>
    <h1>Recuerdos que duran <em>para siempre</em></h1>
    <p class="lede">
      Bodas, quinceañeras, retratos, producto y eventos. Fotografía y video
      para congelar los momentos que se viven una sola vez.
    </p>
    <p class="scroll-hint">Desliza para ver el trabajo ↓</p>
  </section>

  <section class="section" id="trabajo">
    <div class="wrap">
      <div class="section-head">
        <h2>Trabajo seleccionado</h2>
        <p class="eyebrow">2024 — 2026</p>
      </div>
      <div class="work-grid">
        {
          works.map((w) => (
            <a class={`work-item ${w.size}`} href="#trabajo">
              <figure>
                <img
                  src={w.src}
                  alt={w.title}
                  loading="lazy"
                  style={`--ratio: ${w.ratio}`}
                />
                <figcaption>
                  <span>{w.title}</span>
                  <span>{w.year}</span>
                </figcaption>
              </figure>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section" id="sobre-mi">
    <div class="wrap about">
      <p class="eyebrow">Sobre mí</p>
      <div>
        <p class="bio">
          Soy John Arias, fotógrafo y creador de contenido audiovisual.
          Acompaño bodas, quinces y celebraciones
          <em>congelando recuerdos</em> que duran para siempre.
        </p>
        <div class="meta">
          <span>Producto · Retratos · Bodas · Eventos</span>
          <span>Fotografía y video — disponible para agendar tu fecha</span>
        </div>
      </div>
    </div>
  </section>

  <section class="section contact" id="contacto">
    <div class="wrap">
      <p class="eyebrow">Contacto</p>
      <h2>Hablemos de tu próxima celebración</h2>
      <a class="email" href="mailto:hola@johnarias.com">hola@johnarias.com</a>
    </div>
  </section>
</Base>
